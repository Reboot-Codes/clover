{
  "tab_size": 2,
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        // Use `-p` instead of `--workspace` for cargo check
        "check": {
          "workspace": false
        }
      }
    },
    "deno": {
      "settings": {
        "deno": {
          "enable": true
        }
      }
    }
  },
  "languages": {
    "TypeScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint"
      ],
      "formatter": "language_server"
    },
  },
  "file_types": {
    "JSONC": [
      "**/*.clover.jsonc"
    ]
  }
}
